# Optional: CoinGecko API key if you hit rate limits
# COINGECKO_API_KEY=

# Optional: Polymarket (no key needed for public read)
# POLYMARKET_API_KEY=

# Snapshots / reviews (SQLite)
# - Demo deployments should disable snapshots: PPE_ENABLE_SNAPSHOTS=0
# - Full deployments should enable snapshots and set a persistent path:
#   PPE_ENABLE_SNAPSHOTS=1
#   PPE_SNAPSHOT_DB_PATH=/data/ppe_frozen_evaluations.sqlite3
# PPE_ENABLE_SNAPSHOTS=1
# PPE_SNAPSHOT_DB_PATH=

# DB path (default: ./data/engine.db)
# DB_PATH=data/engine.db
