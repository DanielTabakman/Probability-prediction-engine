# Optional: CoinGecko API key if you hit rate limits
# COINGECKO_API_KEY=

# Optional: Polymarket (no key needed for public read)
# POLYMARKET_API_KEY=

# Snapshots / reviews (SQLite)
# - Demo deployments should disable snapshots: PPE_ENABLE_SNAPSHOTS=0
# - Full deployments should enable snapshots and set a persistent path:
#   PPE_ENABLE_SNAPSHOTS=1
#   PPE_SNAPSHOT_DB_PATH=/data/ppe_frozen_evaluations.sqlite3
# PPE_ENABLE_SNAPSHOTS=1
# PPE_SNAPSHOT_DB_PATH=

# Demo only: URL shown as “sign in to save work” when PPE_ENABLE_SNAPSHOTS=0
# PPE_PRIVATE_APP_URL=https://app.marketstructureos.com

# Demo only: research-beta offer CTA (https:// or mailto:) when PPE_ENABLE_SNAPSHOTS=0
# Loaded by docker-compose app_demo (${PPE_RESEARCH_OFFER_URL:-}) — copy to repo-root .env on VPS
# PPE_RESEARCH_OFFER_URL=mailto:you@example.com?subject=PPE%20research%20beta
# PPE_RESEARCH_OFFER_LABEL=Request research beta access

# Feedback panel: off on public demo (PPE_ENABLE_SNAPSHOTS=0) by default; set PPE_ENABLE_FEEDBACK=1 to override
# PPE_ENABLE_FEEDBACK=0

# Developer-only: show the top “Debug: performance” expander in the Streamlit app (default: off)
# PPE_SHOW_DEBUG_UI=1

# DB path (default: ./data/engine.db)
# DB_PATH=data/engine.db

# VPS Phase B TLS: Cloudflare Origin cert + Full (strict) — see certs/README.md
# PPE_CADDYFILE=./Caddyfile.tls

# MSOS Next.js build-time public env (docker-compose build args on msos_web)
# NEXT_PUBLIC_MSOS_SIGN_IN_URL=https://app.marketstructureos.com
# NEXT_PUBLIC_PPE_EMBED_URL=/ppe-embed

# MSOS commercial — Lemon Squeezy (runtime on msos_web; see docs/SOP/LEMON_SQUEEZY_OPERATOR_SETUP_V1.md)
# MSOS_UPGRADE_OFFER_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...
# LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret
