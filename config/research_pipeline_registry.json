{
  "version": 1,
  "collectors": [
    {
      "id": "cross_venue_event_gap",
      "label": "Cross-venue PM ↔ Deribit options",
      "script": "scripts/collect_cross_venue_snapshot.py",
      "cmd": "collect_cross_venue_snapshot.cmd",
      "archive_root": "artifacts/cross_venue_snapshots",
      "file_glob": "**/ppe_cross_venue_prob_panel_*.csv",
      "min_calendar_days": 14,
      "stale_hours": 36,
      "install_task": "install_cross_venue_collector_task.cmd",
      "schedule": "daily 07:15 VM"
    },
    {
      "id": "options_horizon_surface",
      "label": "Options Horizon surface",
      "script": "scripts/collect_horizon_surface_snapshot.py",
      "cmd": "collect_horizon_surface_snapshot.cmd",
      "archive_root": "artifacts/horizon_surface_archive",
      "file_glob": "**/horizon_surface_*.json",
      "min_calendar_days": 30,
      "stale_hours": 36,
      "install_task": "install_horizon_surface_collector_task.cmd",
      "schedule": "daily 06:30 VM"
    },
    {
      "id": "implied_distribution_ts",
      "label": "BTC distribution stats",
      "script": "scripts/collect_distribution_stats_snapshot.py",
      "cmd": "collect_distribution_stats_snapshot.cmd",
      "archive_root": "artifacts/distribution_snapshots",
      "file_glob": "**/ppe_btc_distribution_stats_*.csv",
      "min_calendar_days": 7,
      "stale_hours": 36,
      "install_task": "install_distribution_collector_task.cmd",
      "schedule": "daily 07:45 VM"
    }
  ],
  "tests": [
    {
      "id": "cross_venue_scan",
      "label": "Cross-venue gap scan",
      "script": "scripts/run_cross_venue_scan.py",
      "cmd": "run_cross_venue_scan.cmd",
      "reads_collectors": ["cross_venue_event_gap"],
      "min_calendar_days": 1,
      "report_root": "artifacts/cross_venue_reports",
      "run_args": ["--latest-snapshot"],
      "fatal": false
    },
    {
      "id": "cross_venue_backtest",
      "label": "Cross-venue backtest",
      "script": "scripts/run_cross_venue_backtest.py",
      "cmd": "run_cross_venue_backtest.cmd",
      "reads_collectors": ["cross_venue_event_gap"],
      "min_calendar_days": 14,
      "report_root": "artifacts/cross_venue_backtest",
      "run_args": [],
      "fatal": false
    },
    {
      "id": "cross_venue_tradeability",
      "label": "Cross-venue tradeability",
      "script": "scripts/run_cross_venue_tradeability.py",
      "cmd": "run_cross_venue_tradeability.cmd",
      "reads_collectors": ["cross_venue_event_gap"],
      "min_calendar_days": 1,
      "report_root": "artifacts/cross_venue_tradeability",
      "run_args": ["--latest-snapshot"],
      "fatal": false
    },
    {
      "id": "cross_venue_tradeability_backtest",
      "label": "Cross-venue tradeability backtest",
      "script": "scripts/run_cross_venue_tradeability_backtest.py",
      "cmd": "run_cross_venue_tradeability_backtest.cmd",
      "reads_collectors": ["cross_venue_event_gap"],
      "min_calendar_days": 14,
      "report_root": "artifacts/cross_venue_tradeability_backtest",
      "run_args": [],
      "fatal": false
    }
  ]
}
