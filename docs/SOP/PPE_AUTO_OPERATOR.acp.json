{
  "version": 1,
  "profile": "acp",
  "enabled": true,
  "notes": "With agent credits: npm ppe-orchestrator-acp + Cursor SDK steward charter. Requires CURSOR_API_KEY and sibling ppe-orchestrator-acp repo.",
  "propagateBacklog": true,
  "stewardCharter": true,
  "workerMode": "acp",
  "skipAcp": false,
  "continuousMax": 20,
  "loopWhenIdle": true,
  "idleSleepSeconds": 120,
  "guards": {
    "enabled": true,
    "stopOnContextEscalate": true,
    "stopOnContextWatch": false,
    "maxPhaseSlices": 6,
    "blockProductUnderGlobalDeterministic": false,
    "requireTouchSetOnProductSlices": true,
    "skipChapterIfEvidenceComplete": true,
    "maxConsecutivePhaseFailures": 2,
    "runQueueHealthBeforeChapter": true
  }
}
