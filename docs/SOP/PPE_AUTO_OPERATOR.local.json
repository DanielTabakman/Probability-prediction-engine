{
  "version": 1,
  "profile": "local",
  "enabled": true,
  "notes": "No API credits: deterministic relay; product BUILD in Cursor IDE, then run_ppe_local.cmd. See PPE_IDE_NATIVE_OPERATOR_V1.md.",
  "propagateBacklog": true,
  "focusGate": false,
  "stewardCharter": false,
  "workerMode": "deterministic",
  "skipAcp": true,
  "continuousMax": 20,
  "loopWhenIdle": true,
  "idleSleepSeconds": 120,
    "gitSync": {
    "enabled": true,
    "pullEachPass": true,
    "publishEachPass": true,
    "mergeEachPass": true,
    "pullBranch": "main",
    "checkoutMainWhenOpsBranch": true,
    "pushAfterCommit": true,
    "openPrOnPush": true
  },
  "guards": {
    "enabled": true,
    "blockProductUnderGlobalDeterministic": true,
    "stopOnContextEscalate": false,
    "stopOnContextWatch": false,
    "maxPhaseSlices": 6,
    "phaseSliceBatching": true,
    "skipChapterIfEvidenceComplete": true
  },
  "guardStopSleepSeconds": 300,
  "keepLoopAliveOnGuardStop": true,
  "autoRemoteBuild": false,
  "ideHandoff": {
    "enabled": true,
    "openCursor": false,
    "skipCliWhenUsageExhausted": true,
    "preferIdeOverCli": true,
    "postBuildWatcher": true,
    "localTriggerWatcher": true
  },
  "desktopStack": {
    "mode": "headless",
    "notes": "One supervisor process + detached workers; use run_ppe_headless_stack.cmd. See PPE_HEADLESS_STACK_V1.md."
  }
}
