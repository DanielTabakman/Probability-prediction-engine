{
  "version": 1,
  "profile": "local",
  "enabled": true,
  "notes": "No API credits: deterministic relay; product BUILD in Cursor IDE, then auto run_ppe_local. See PPE_IDE_NATIVE_OPERATOR_V1.md.",
  "propagateBacklog": true,
  "stewardCharter": false,
  "workerMode": "deterministic",
  "skipAcp": true,
  "continuousMax": 20,
  "loopWhenIdle": true,
  "minLoopSleepSeconds": 5,
  "idleSleepSeconds": 5,
  "supplyLowSleepSeconds": 60,
  "workerPollSleepSeconds": 10,
  "maintenanceLoopSleepSeconds": 300,
  "idleAlertMinutes": 20,
  "autoRunLocal": true,
  "gitSync": {
    "enabled": true,
    "pullEachPass": true,
    "publishEachPass": true,
    "pullBranch": "main",
    "checkoutMainWhenOpsBranch": true,
    "pushAfterCommit": true,
    "openPrOnPush": true
  },
  "guards": {
    "enabled": true,
    "blockProductUnderGlobalDeterministic": true,
    "stopOnContextEscalate": true,
    "stopOnContextWatch": false,
    "maxPhaseSlices": 6,
    "phaseSliceBatching": true,
    "skipChapterIfEvidenceComplete": true
  },
  "guardStopSleepSeconds": 15,
  "keepLoopAliveOnGuardStop": true,
  "autoRemoteBuild": true,
  "ideHandoff": {
    "enabled": true,
    "openCursor": true,
    "skipCliWhenUsageExhausted": true,
    "preferIdeOverCli": false,
    "postBuildWatcher": true
  }
}
