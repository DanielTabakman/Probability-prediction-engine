{
  "version": 1,
  "profile": "local",
  "enabled": true,
  "notes": "No API credits: deterministic relay; product BUILD in Cursor IDE, then run_ppe_local.cmd. See PPE_IDE_NATIVE_OPERATOR_V1.md.",
  "propagateBacklog": true,
  "stewardCharter": false,
  "workerMode": "deterministic",
  "skipAcp": true,
  "continuousMax": 20,
  "loopWhenIdle": true,
  "idleSleepSeconds": 120,
    "gitSync": {
    "enabled": true,
    "pullEachPass": true,
    "publishEachPass": true,
    "pullBranch": "main",
    "checkoutMainWhenOpsBranch": true,
    "pushAfterCommit": true,
    "openPrOnPush": true
  },
  "guards": {
    "enabled": true,
    "blockProductUnderGlobalDeterministic": true,
    "stopOnContextEscalate": true,
    "stopOnContextWatch": false,
    "maxPhaseSlices": 6,
    "phaseSliceBatching": true,
    "skipChapterIfEvidenceComplete": true
  },
  "guardStopSleepSeconds": 300,
  "keepLoopAliveOnGuardStop": true,
  "autoRemoteBuild": true,
  "ideHandoff": {
    "enabled": true,
    "openCursor": true,
    "skipCliWhenUsageExhausted": true
  }
}
