@echo off
REM Copy to ppe_operator_notify.local.cmd (gitignored) and set your ntfy topic.
REM Subscribe to the same topic in the ntfy app on your phone.

set "PPE_NTFY_TOPIC=ppe-your-secret-topic-here"
REM Stuck/in-flight alerts on a separate topic (subscribe on phone for urgent only):
REM set "PPE_NTFY_TOPIC_STUCK=ppe-your-stuck-topic-here"
REM Volume control (defaults: cap 40/day, chapter-only progress, heartbeat every 24h):
REM set "PPE_NTFY_DAILY_CAP=40"
REM set "PPE_NTFY_PROGRESS=chapter"
REM Chapter closeout pings include "Check in:" hints; pipeline-idle ping when queue empty:
REM set "PPE_NTFY_CHECK_IN=1"
REM set "PPE_NTFY_HEARTBEAT_HOURS=24"
REM set "PPE_NTFY_HEARTBEAT_HOURS=0"
REM Stuck reminder while verdict unchanged (IDE_BUILD, ERROR, etc.). Default 8; 2 = every 2h.
REM During quiet hours: one stuck ping per night, then silence until morning.
REM set "PPE_NTFY_STUCK_HOURS=2"
REM Loop-down cooldown (default 30m) — stops restart death-spiral ntfy spam; loop-down excluded from daily cap.
REM set "PPE_NTFY_LOOP_DOWN_COOLDOWN_MIN=30"
REM Quiet hours: mute routine auto-alerts (phone cmds + stuck + urgent still work).
REM set "PPE_NTFY_QUIET_HOURS=1"
REM set "PPE_NTFY_QUIET_START=01:00"
REM set "PPE_NTFY_QUIET_END=08:00"
REM 8am local digest (requires watch_operator_mobile running).
REM set "PPE_NTFY_MORNING_REPORT=1"
REM set "PPE_NTFY_MORNING_REPORT_AT=08:00"
REM Phone command poll interval (default 30s; SSE optional via PPE_NTFY_CMD_SSE=1):
REM set "PPE_NTFY_CMD_POLL_SEC=30"
REM Weekly digest to phone (skip desktop toast):
REM set "PPE_WEEKLY_DIGEST_TOAST=0"
REM Optional private server or authenticated topic:
REM set "PPE_NTFY_SERVER=https://ntfy.sh"
REM set "PPE_NTFY_TOKEN=your-token-if-using-auth"
REM Phone commands (watch_ntfy_commands.cmd): build | restart | fix | status | snooze | help
REM Snooze examples from phone: snooze | snooze 6 | snooze 30m | snooze until 08:00 | snooze clear
REM Required for build/fix/restart/status/snooze (help works without secret):
set "PPE_NTFY_CMD_SECRET=your-long-random-secret-here"
REM Disable phone commands: set "PPE_NTFY_CMD_ENABLED=0"
REM Near-zero API (recommended): copy ppe_operator_near_zero_api.local.cmd.example
REM Legacy headless CLI auto-build: set "PPE_AUTO_REMOTE_BUILD=1"
