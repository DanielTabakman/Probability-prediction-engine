@echo off
REM Copy to ppe_operator_notify.local.cmd (gitignored) and set your ntfy topic.
REM Subscribe to the same topic in the ntfy app on your phone.

set "PPE_NTFY_TOPIC=ppe-your-secret-topic-here"
REM Weekly digest to phone (skip desktop toast):
REM set "PPE_WEEKLY_DIGEST_TOAST=0"
REM Optional private server or authenticated topic:
REM set "PPE_NTFY_SERVER=https://ntfy.sh"
REM set "PPE_NTFY_TOKEN=your-token-if-using-auth"
REM Phone commands (watch_ntfy_commands.cmd): build | restart | fix | status | help
REM Optional secret prefix: set "PPE_NTFY_CMD_SECRET=my-secret" then send "my-secret build"
REM Disable phone commands: set "PPE_NTFY_CMD_ENABLED=0"
REM Auto-start agent CLI on IDE_BUILD (default on): set "PPE_AUTO_REMOTE_BUILD=1"
