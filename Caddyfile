# Routing: apex (default) -> msos_web:3000 (Next.js MSOS); app.marketstructureos.com -> app_full:8501 (Streamlit).
# Deploy notes: docs/DEPLOY/MSOS_WEB_V1.md
#
# Origin serves HTTP only for now (reliable for raw IP + pre-DNS testing).
# Cloudflare "Full (strict)" needs a TLS cert on the origin later — use a
# Cloudflare Origin Certificate + tls /path/to/cert.pem /path/to/key.pem
# in a second server block, or switch auto_https back on after DNS works.
#
# Streamlit builds absolute URLs for lazy-loaded /static/js chunks. Behind
# Cloudflare Flexible, the hop to this origin is HTTP, so we must forward the
# visitor's scheme (X-Forwarded-Proto) or chunks load as http:// and break HTTPS.
#
# We split Cloudflare vs direct traffic: a two-input `map` cannot use both
# `"" ""` and `"" *` because `*` matches an empty CF-Ray, which duplicates the
# empty+empty case and makes Caddy reject the config (crash loop → CF 521).
{
	auto_https off
}

:80 {
	encode gzip

	# Proxied through Cloudflare (CF-Ray present): default proto is HTTPS when
	# X-Forwarded-Proto is absent so Streamlit emits https chunk URLs.
	@cloudflare header CF-Ray *
	handle @cloudflare {
		map {http.request.header.X-Forwarded-Proto} {forwarded_proto} {
			https https
			HTTPS https
			http http
			HTTP http
			default https
		}
		@app host app.marketstructureos.com
		handle @app {
			reverse_proxy app_full:8501 {
				header_up X-Forwarded-Proto {forwarded_proto}
				header_up X-Forwarded-Host {http.request.host}
			}
		}
		handle {
			reverse_proxy msos_web:3000 {
				header_up X-Forwarded-Proto {forwarded_proto}
				header_up X-Forwarded-Host {http.request.host}
			}
		}
	}

	# Direct-to-origin (no CF-Ray): trust X-Forwarded-Proto when set, else TCP scheme.
	handle {
		map {http.request.header.X-Forwarded-Proto} {forwarded_proto} {
			https https
			HTTPS https
			http http
			HTTP http
			default {http.request.scheme}
		}
		@app host app.marketstructureos.com
		handle @app {
			reverse_proxy app_full:8501 {
				header_up X-Forwarded-Proto {forwarded_proto}
				header_up X-Forwarded-Host {http.request.host}
			}
		}
		handle {
			reverse_proxy msos_web:3000 {
				header_up X-Forwarded-Proto {forwarded_proto}
				header_up X-Forwarded-Host {http.request.host}
			}
		}
	}
}
