# Routing: apex (default) -> msos_web:3000 (Next.js MSOS); app.marketstructureos.com -> app_full:8501 (Streamlit).
# Strategy Lab PPE embed: /ppe-embed/* -> app_demo:8501 (public Streamlit; see MSOS_P1_STACK_ROUTING_ADR).
# Display API: /ppe-display-api/* -> ppe_display_api:8765 (read-only JSON; embed_display_boundary).
# Deploy notes: docs/DEPLOY/MSOS_WEB_V1.md
#
# Phase A (this file): HTTP on :80 — pair with Cloudflare SSL mode **Flexible**.
# Phase B: use Caddyfile.tls + origin certs (see certs/README.md and RUNBOOK_VPS_CLOUDFLARE_ACCESS.md §5).
#
# Streamlit builds absolute URLs for lazy-loaded /static/js chunks. Behind
# Cloudflare Flexible, the hop to this origin is HTTP, so we must forward the
# visitor's scheme (X-Forwarded-Proto) or chunks load as http:// and break HTTPS.

import caddy/snippets.caddy

{
	auto_https off
}

:80 {
	encode gzip
	import security_headers

	@cloudflare header CF-Ray *
	handle @cloudflare {
		import site_handlers_cloudflare
	}
	handle {
		import site_handlers_direct
	}
}
