REM Emergency paste handoff only — normal desktop uses PPE_IDE_HANDOFF_CLIPBOARD=0
set "PPE_IDE_HANDOFF_CLIPBOARD=1"
set "PPE_SKIP_CLI_WHEN_USAGE_EXHAUSTED=1"

REM Emergency only — one headless CLI build from phone:
