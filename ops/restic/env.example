# Copy this file to env.local on the VPS and fill values.
#
# Keep env.local out of git.

# R2 / S3 credentials (Cloudflare R2: create in R2 dashboard)
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# Cloudflare R2 S3 endpoint (example format)
# export RESTIC_REPOSITORY="s3:https://<accountid>.r2.cloudflarestorage.com/<bucket-name>"
export RESTIC_REPOSITORY=""

# A long unique passphrase for restic repository encryption
export RESTIC_PASSWORD=""

# Optional: for some restic builds / S3 configs
export AWS_DEFAULT_REGION="auto"

